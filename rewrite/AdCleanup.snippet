# > 谷歌 重定向
; hostname = www.google.cn, maps.google.cn, translate.google.cn, ditu.google.cn
# 搜索页
^https?:\/\/www\.google\.cn url 302 https://www.google.com
# Maps 地图
^https?:\/\/(maps|ditu)\.google\.cn url 302 https://maps.google.com
# Translate 翻译
^https?:\/\/translate\.google\.cn url 302 https://translate.google.com


